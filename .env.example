# Copy to .env and fill in values for local development
# Never commit .env to git

# Flask
SECRET_KEY=your-random-32-byte-hex-here
FLASK_ENV=development
PREPPY_DEBUG=1

# Postgres — use a local Postgres or docker-compose
DATABASE_URL=postgresql://preppy:preppy@localhost:5432/preppy

# Planning Center OAuth
# Register your app at https://api.planningcenteronline.com/oauth/applications
PCO_CLIENT_ID=your-pco-client-id
PCO_CLIENT_SECRET=your-pco-client-secret
PCO_REDIRECT_URI=http://localhost:5000/auth/callback
